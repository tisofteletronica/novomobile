{
  "expo": {
    "name": "softmobile",
    "slug": "softmobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/iconios.png",
    "scheme": "softmobile",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/icon2.png"
      },
      "package": "br.com.instalesoft"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo.png",
          "imageWidth": 240,
          "resizeMode": "contain",
          "backgroundColor": "#1C61AC"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "016d4568-effb-4ab3-9ba5-d5544e276bf5"
      }
    },
    "owner": "jeanfurquim"
  }
}
